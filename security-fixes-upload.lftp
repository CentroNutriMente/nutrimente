set ftp:ssl-allow false
set ftp:passive-mode true
set net:timeout 60
set xfer:clobber on
# Build (assets prima, manifest per ultimo)
mirror -R --ignore-time --parallel=2 --no-perms /Users/alfonso/nutrimente/nutrimente/public/build/assets www.saraalessandripsicologa.it/build/assets
put /Users/alfonso/nutrimente/nutrimente/public/build/manifest.json -o www.saraalessandripsicologa.it/build/manifest.json
# Controller con fix di autorizzazione (IDOR / broken access control)
put /Users/alfonso/nutrimente/nutrimente/app/Http/Controllers/DocumentController.php -o www.saraalessandripsicologa.it/nutrimente_app/app/Http/Controllers/DocumentController.php
