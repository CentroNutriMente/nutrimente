put /Users/alfonso/nutrimente/nutrimente/database/migrations/2026_06_25_120000_add_codice_fiscale_to_group_enrollment_requests.php -o www.saraalessandripsicologa.it/nutrimente_app/database/migrations/2026_06_25_120000_add_codice_fiscale_to_group_enrollment_requests.php
