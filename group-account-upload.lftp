mkdir -p www.saraalessandripsicologa.it/nutrimente_app/app/Services
put /Users/alfonso/nutrimente/nutrimente/app/Services/PatientRegistrar.php -o www.saraalessandripsicologa.it/nutrimente_app/app/Services/PatientRegistrar.php
# controller + modello + migrazione
put /Users/alfonso/nutrimente/nutrimente/app/Http/Controllers/GroupController.php -o www.saraalessandripsicologa.it/nutrimente_app/app/Http/Controllers/GroupController.php
