# =============================================================================
# NutriMente — production .env for Aruba Hosting Linux (Easy)
# Place this as:  nutrimente_app/.env   (create it on the server; it is gitignored)
# Fill every <...> placeholder. Do NOT commit the real file.
# =============================================================================

APP_NAME=NutriMente
APP_ENV=production
# Reuse the SAME key as your current local .env (copy it verbatim). Avoids any
# surprises; a fresh `php artisan key:generate` is also fine since you are NOT
# migrating sessions or encrypted rows.
APP_KEY=base64:<generate-with-php-artisan-key:generate-or-copy-from-local-.env>
APP_DEBUG=false
APP_URL=https://www.saraalessandripsicologa.it

APP_LOCALE=it
APP_FALLBACK_LOCALE=it
APP_FAKER_LOCALE=it_IT

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# --- Logging ------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# --- Database: Aruba MySQL (Easy = MySQL only, no PostgreSQL) ------------------
# Get these from the Aruba panel (Database MySQL section). The host is usually a
# dedicated Aruba DB hostname, NOT localhost.
DB_CONNECTION=mysql
DB_HOST=31.11.39.220
DB_PORT=3306
DB_DATABASE=Sql1945528_1
# Username is ONLY the account id — do NOT append "@<host-ip>". MySQL reads
# 'user'@'host' as two fields, so an @ in the username is treated as part of
# the literal username and auth fails (1045 Access denied).
DB_USERNAME=Sql1945528
DB_PASSWORD=<aruba-mysql-password>
# (No DB_SSLMODE — that was Supabase/Postgres only.)

# --- Sessions / cache / queue -------------------------------------------------
# database driver => tables created by `php artisan migrate`. No Redis on Easy.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database

# sync => jobs run inside the web request. You have no queued (ShouldQueue)
# jobs, so this is correct and needs no worker process.
QUEUE_CONNECTION=sync
BROADCAST_CONNECTION=log

# --- Filesystem ---------------------------------------------------------------
# You are on local disk: uploaded files live in nutrimente_app/storage/app.
FILESYSTEM_DISK=local

# --- Mail: Aruba SMTP for this domain -----------------------------------------
# Aruba mailbox SMTP. Use the full mailbox address as the username.
MAIL_MAILER=smtp
MAIL_HOST=smtps.aruba.it
MAIL_PORT=465
MAIL_SCHEME=smtps
MAIL_USERNAME=<your-mailbox@saraalessandripsicologa.it>
MAIL_PASSWORD=<mailbox-password>
MAIL_FROM_ADDRESS="<your-mailbox@saraalessandripsicologa.it>"
MAIL_FROM_NAME="${APP_NAME}"
# Alternative if 465/SSL is blocked: MAIL_PORT=587 and MAIL_SCHEME=null (STARTTLS)

# --- AWS S3 -------------------------------------------------------------------
# Not used while FILESYSTEM_DISK=local. Leave blank / delete this block.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=
# AWS_BUCKET=
# AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
